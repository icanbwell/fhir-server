<?xml version="1.0"?>
<!--
    Enables experimental features required by DDL in clickhouse-init/.
    allow_experimental_json_type: required by fhir.AuditEvent_4_0_0 Native JSON column.

    Loaded into /etc/clickhouse-server/users.d/ via docker-compose bind mount.
-->
<clickhouse>
    <profiles>
        <default>
            <allow_experimental_json_type>1</allow_experimental_json_type>
        </default>
    </profiles>
</clickhouse>
