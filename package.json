{
  "name": "bwell-fhir-server",
  "version": "0.0.1",
  "description": "R4 compliant FHIR SERVER",
  "main": "src/index.js",
  "repository": "https://github.com/icanbwell/fhir-server",
  "license": "MIT",
  "engines": {
    "node": ">=24.14"
  },
  "scripts": {
    "start": "NODE_ENV=production node src/index.js",
    "dev": "NODE_ENV=development node --require=./src/otel_instrumentation.js --watch src/index.js;",
    "dev_debug": "NODE_ENV=development DEBUG=express:router node src/index.js;",
    "test": "NODE_ENV=test yarn run lint && yarn run test:jest",
    "test:mem_leak": "NODE_ENV=test node --inspect-brk --expose-gc ./node_modules/.bin/jest --runInBand --logHeapUsage -i src/tests/performance/search_by_id_many/search_by_id_many.csv.test.js",
    "test:functional": "NODE_ENV=test yarn run lint && yarn run test:jest_functional",
    "test:performance": "NODE_ENV=test node --max-old-space-size=40960 --optimize_for_size --gc_interval=100 ./node_modules/.bin/jest --no-watchman --silent --logHeapUsage --runInBand --forceExit --testTimeout=600000 src/tests/performance",
    "coverage": "NODE_ENV=test yarn run lint && yarn run test:jest_coverage",
    "test_shards": "NODE_ENV=test yarn run lint && yarn run test:jest_cleanCache && yarn run test:jest_shard1 && yarn run test:jest_shard2 && yarn run test:jest_shard3 && yarn run test:jest_shard4 && yarn run test:jest_shard5",
    "lint": "NODE_ENV=test yarn run test:lint",
    "test:failed": "NODE_ENV=test yarn run test:lint && yarn run test:jest --onlyFailures",
    "test:lint": "NODE_OPTIONS=\"${NODE_OPTIONS:-} --max-old-space-size=8096\" eslint \"src/**/*.js\"",
    "test:jest_cleanCache": "node --max-old-space-size=10240 --optimize_for_size --gc_interval=100 ./node_modules/.bin/jest --no-watchman --silent --logHeapUsage --clearCache --runInBand --forceExit .",
    "test:jest_shard1": "node --max-old-space-size=20240 --optimize_for_size --gc_interval=100 ./node_modules/.bin/jest --no-watchman --silent --logHeapUsage --runInBand --forceExit --shard=1/5 .",
    "test:jest_shard2": "node --max-old-space-size=20240 --optimize_for_size --gc_interval=100 ./node_modules/.bin/jest --no-watchman --silent --logHeapUsage --runInBand --forceExit --shard=2/5 .",
    "test:jest_shard3": "node --max-old-space-size=20240 --optimize_for_size --gc_interval=100 ./node_modules/.bin/jest --no-watchman --silent --logHeapUsage --runInBand --forceExit --shard=3/5 .",
    "test:jest_shard4": "node --max-old-space-size=20240 --optimize_for_size --gc_interval=100 ./node_modules/.bin/jest --no-watchman --silent --logHeapUsage --runInBand --forceExit --shard=4/5 .",
    "test:jest_shard5": "node --max-old-space-size=20240 --optimize_for_size --gc_interval=100 ./node_modules/.bin/jest --no-watchman --silent --logHeapUsage --runInBand --forceExit --shard=5/5 .",
    "test:jest": "node --max-old-space-size=20240 --optimize_for_size --gc_interval=100 ./node_modules/.bin/jest --no-watchman --silent --logHeapUsage --runInBand --forceExit .",
    "test:jest_functional": "node --max-old-space-size=10240 --optimize_for_size --gc_interval=100 ./node_modules/.bin/jest --no-watchman --silent --logHeapUsage --runInBand --forceExit --testPathIgnorePatterns='<rootDir>/src/tests/performance/' .",
    "test:jest_coverage": "node --max-old-space-size=10240 --optimize_for_size --gc_interval=100 ./node_modules/.bin/jest --no-watchman --silent --logHeapUsage --clearCache --runInBand --forceExit --coverage --testPathIgnorePatterns='<rootDir>/src/tests/performance/' .",
    "test:jestInspect": "NODE_ENV=test node --max-old-space-size=12328 --inspect-brk --expose-gc ./node_modules/.bin/jest --no-watchman --silent --useStderr --logHeapUsage --detectOpenHandles -i src/tests/practitioner/complex_merge src/tests/patient/search_by_id/search_by_id.test.js",
    "test:integration": "NODE_ENV=test jest --forceExit --detectOpenHandles -i src/tests/practitioner/complex_merge",
    "test:specific": "NODE_ENV=test jest --forceExit --detectOpenHandles -i src/tests/patient/search_by_id/search_by_id.test.js",
    "test:everything": "NODE_ENV=test jest --forceExit --detectOpenHandles -i src/tests/practitioner/everything",
    "test:graphql": "NODE_ENV=test jest --forceExit --detectOpenHandles -i src/tests/graphql",
    "test:merge": "NODE_ENV=test jest --forceExit --detectOpenHandles -i src/tests/practitioner/practitioner.merge.test.js",
    "test:search": "NODE_ENV=test jest --forceExit --detectOpenHandles -i src/tests/searchParameters/search_by* src/tests/patient/search_by* src/tests/operations/query/r4/r4.test.js",
    "test:perf:clickhouse": "RUN_CLICKHOUSE_PERF=1 NODE_ENV=test node --max-old-space-size=20240 --optimize_for_size --gc_interval=100 ./node_modules/.bin/jest --no-watchman --logHeapUsage --runInBand --forceExit src/tests/group/group_clickhouse_performance.test.js",
    "prepare": "",
    "prettier-check": "prettier --check \"**/*.{js,mjs,cjs,jsx,json,ts,tsx,md,mdx,css,html,yml,yaml,scss,less,graphql,graphqls,gql}\"",
    "prettier-fix": "prettier --write \"**/*.{js,mjs,cjs,jsx,json,ts,tsx,md,mdx,css,html,yml,yaml,scss,less,graphql,graphqls,gql}\"",
    "fix_lint": "eslint --fix \"src/**/*.js\""
  },
  "graphql-schema-linter": {
    "rules": [
      "enum-values-sorted-alphabetically"
    ],
    "schemaPaths": [
      "src/graphql/schemas/**.graphql",
      "src/graphqlv2/schemas/**.graphql"
    ],
    "customRulePaths": [
      "src/graphql/resolvers/*.js",
      "src/graphqlv2/resolvers/*.js"
    ],
    "rulesOptions": {
      "enum-values-sorted-alphabetically": {
        "sortOrder": "lexicographical"
      }
    }
  },
  "dependencies": {
    "@apollo/server": "5.5.1",
    "@apollo/subgraph": "^2.14.0",
    "@as-integrations/express5": "^1.1.2",
    "@asymmetrik/fhir-json-schema-validator": "^0.9.8",
    "@asymmetrik/sof-scope-checker": "^1.0.7",
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/lib-storage": "^3.1053.0",
    "@clickhouse/client": "^1.18.5",
    "@godaddy/terminus": "^4.12.1",
    "@graphql-tools/load-files": "^7.0.1",
    "@graphql-tools/merge": "^9.1.9",
    "@icanbwell/fhir-to-csv": "^1.0.16",
    "@icanbwell/fhirpatientsummary": "^1.0.47",
    "@json2csv/node": "^7.0.6",
    "@json2csv/transforms": "^7.0.6",
    "@kubernetes/client-node": "1.4.0",
    "@mongodb-js/zstd": "^2.0.1",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.76.0",
    "@opentelemetry/core": "2.7.1",
    "@opentelemetry/exporter-metrics-otlp-grpc": "0.218.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.218.0",
    "@opentelemetry/instrumentation": "0.218.0",
    "@opentelemetry/instrumentation-dataloader": "0.35.0",
    "@opentelemetry/instrumentation-express": "0.66.0",
    "@opentelemetry/instrumentation-graphql": "0.66.0",
    "@opentelemetry/instrumentation-http": "0.218.0",
    "@opentelemetry/instrumentation-lru-memoizer": "0.62.0",
    "@opentelemetry/instrumentation-mongodb": "0.71.0",
    "@opentelemetry/instrumentation-redis": "0.66.0",
    "@opentelemetry/instrumentation-router": "0.62.0",
