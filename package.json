    "cloudevents": "^10.0.0",
    "compression": "^1.8.1",
    "content-type": "^2.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cron": "^4.4.0",
    "dataloader": "^2.2.3",
    "deepcopy": "^2.1.0",
    "deepmerge": "^4.3.1",
    "express": "^5.2.1",
    "express-http-context": "^2.0.1",
    "express-useragent": "^2.2.0",
    "fast-deep-equal": "^3.1.3",
    "fast-json-patch": "^3.1.1",
    "fflate": "^0.8.3",
    "graphql": "^16.14.0",
    "graphql-fields": "^2.0.3",
    "graphql-parse-resolve-info": "^4.14.1",
    "helmet": "^8.2.0",
    "jwks-rsa": "^4.0.1",
    "kafkajs": "^2.2.4",
